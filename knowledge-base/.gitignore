# ============================
# 敏感文件 - 严格排除
# ============================

# 环境变量与密钥
*.env
.env.*
*.key
*.pem
*.p12
*.pfx
*secrets*
*credentials*
*password*

# API Token / 配置
config.local.*
.private/
.personal/
secrets/

# ============================
# 操作系统文件
# ============================
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ============================
# IDE / 编辑器
# ============================
.vscode/
.idea/
*.sublime-*

# ============================
# 大文件 - 不适合 Git 管理
# ============================
*.zip
*.tar.gz
*.rar
*.7z
*.mp4
*.avi
*.mov
*.mkv
*.iso

# 大型数据文件
*.sqlite
*.db
*.sql.gz

# ============================
# 构建产物
# ============================
site/
build/
dist/
node_modules/
__pycache__/
*.pyc

# ============================
# 临时文件
# ============================
tmp/
temp/
*.tmp
*.bak
*.log
